# =============================================================================
# Repository root — FastAPI API only (apps/api)
# =============================================================================
# Loaded by apps/api/main.py from THIS directory (not frontend/).
# Frontend env lives in frontend/.env.local — see frontend/.env.example
#
# Naming split:
#   API_BASE_URL     = public origin of the FastAPI app (CORS + self-reference)
#   FRONTEND_URL     = origin where the Next.js app runs (CORS)
# Browser calls use NEXT_PUBLIC_API_URL in frontend — usually same host as API_BASE_URL
# in dev (http://localhost:8000) because Next is on :3000 and API on :8000.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (required by pydantic Settings in apps/api/core/config.py)
# -----------------------------------------------------------------------------
NODE_ENV=development
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Clerk — API validates session JWTs via JWKS (not the Next publishable key)
# -----------------------------------------------------------------------------
CLERK_JWT_ISSUER=
# CLERK_JWT_AUDIENCE=

# Optional: only if you call Clerk Backend API from Python. JWT login does not need this.
# CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Supabase (all three required at API startup)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# OpenRouter (required)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OR_MODEL_SIMPLE=
OR_MODEL_REASONING=
OR_MODEL_FAST=
# Optional embedding slug for tools that need it
# OR_MODEL_EMBEDDING=
# Optional 503 / outage fallbacks (see backend/alex_llm/src/alex_llm/llm.py)
# OR_MODEL_REASONING_FALLBACK=
# OR_MODEL_FALLBACK=

# Optional display name sent to OpenRouter
# OPENROUTER_APP_NAME=alex-finance

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
POLYGON_API_KEY=
# POLYGON_PLAN=free

# -----------------------------------------------------------------------------
# Observability (optional — set BOTH keys or omit BOTH)
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_RELEASE=
# LANGFUSE_API_FLUSH_SLEEP_S=0.35
# LANGFUSE_FLUSH_TIMEOUT_S=8

# -----------------------------------------------------------------------------
# AWS — used when SQS is set (enqueue) or when using boto from the API
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
# AWS_REGION_NAME is derived from AWS_REGION at runtime (do not set unless you know why).
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Planner queue. Empty = no remote queue (see MOCK_LAMBDAS / LOCAL_DEV below).
# Production: terraform output -raw sqs_queue_url  (or jq on infra.json in CI)
SQS_QUEUE_URL=

# Optional: bucket id for Lambdas / tooling (Terraform sets on AWS deploy)
S3_BUCKET_UI=

# Child agents when AGENT_EXECUTION_MODE=lambda (defaults match terraform/variables.tf)
# TAGGER_FUNCTION=alex-tagger
# REPORTER_FUNCTION=alex-reporter
# CHARTER_FUNCTION=alex-charter
# RETIREMENT_FUNCTION=alex-retirement

# local = in-process agent handlers; lambda = boto3 Invoke (functions must exist)
AGENT_EXECUTION_MODE=local

# true = run planner inside API after POST /api/analyze (ignores SQS for that path)
MOCK_LAMBDAS=false

# true = allow in-process planner when SQS_QUEUE_URL is unset even if NODE_ENV=production
LOCAL_DEV=false
