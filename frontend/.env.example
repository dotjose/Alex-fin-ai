# =============================================================================
# Next.js app only — copy to frontend/.env.local
# =============================================================================
# Next loads env files from the frontend/ directory (not the repo root).
# FastAPI reads repo-root .env — keep API keys there.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk — publishable key ONLY (embedded in the browser bundle)
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.clerk.com → API Keys → Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Do NOT put CLERK_SECRET_KEY here for this static-export setup; the shipped UI
# talks to FastAPI with Clerk session JWTs. Secret keys belong on the server / CI only.

# -----------------------------------------------------------------------------
# API origin — browser fetch() targets this host + /api/...
# -----------------------------------------------------------------------------
# Local API on port 8000:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: GitHub Actions sets NEXT_PUBLIC_API_URL from terraform output -json
# (cloudfront_url stack by default; set repo variable NEXT_PUBLIC_API_ORIGIN=apigateway to use api_gateway_url).

# Optional: canonical browser origin (e.g. https://xxx.cloudfront.net in prod).
# CI sets this from Terraform cloudfront_url. Useful for absolute links / metadata.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
